# Bot Configuration (REQUIRED)
TOKEN=your_discord_bot_token_here
CLIENT_ID=your_bot_client_id_here

# Database (OPTIONAL - leave blank to run without database)
# Without database: warnings, tickets, and settings won't persist after restart
MONGODB_URI=

# Bot Settings
DEFAULT_PREFIX=!
OWNER_ID=1236891245998243911

# Dashboard (optional)
DASHBOARD_PORT=3000
DASHBOARD_SECRET=your_random_secret_here

# Logging
LOG_CHANNEL_ID=
ERROR_LOG_CHANNEL_ID=
